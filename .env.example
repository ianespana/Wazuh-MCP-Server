# Wazuh MCP Server Configuration
# Production-ready MCP-compliant server for Wazuh SIEM integration
# Copy to .env and update with your settings

# === Wazuh Configuration ===
WAZUH_HOST=https://your-wazuh-server.com
WAZUH_USER=your-api-user
WAZUH_PASS=your-api-password
WAZUH_PORT=55000

# === Deployment Environment ===
# "development" (default) or "production".
# In production, AUTH_SECRET_KEY is REQUIRED (the server refuses to start without it
# unless AUTH_MODE=none) so tokens survive restarts and work across instances.
ENVIRONMENT=development

# === MCP Server Configuration ===
# Host to bind to (use 127.0.0.1 for local only, 0.0.0.0 for all interfaces)
MCP_HOST=127.0.0.1
MCP_PORT=3000
# Transport: http (default). Only HTTP/SSE is implemented.
# MCP_TRANSPORT=http

# === Authentication ===
# Auth mode: bearer (default), oauth, or none (authless)
AUTH_MODE=bearer

# When AUTH_MODE=none (authless), active response/write tools are disabled by default.
# Set to true to explicitly allow write operations without authentication (dangerous
# on a 0.0.0.0 bind — only behind a trusted network/firewall).
# AUTHLESS_ALLOW_WRITE=false

# SECURITY: Generate a secure secret key for production!
# Run: openssl rand -hex 32  — set the SAME value on every instance.
AUTH_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Token lifetime in hours
TOKEN_LIFETIME_HOURS=24

# === API Key Configuration (Recommended for production) ===
# Simple single API key configuration - generate with:
#   python -c "import secrets; print('wazuh_' + secrets.token_urlsafe(32))"
# If not set, server auto-generates a key and displays it on startup
# MCP_API_KEY=wazuh_your-generated-key-here
# Scopes granted to MCP_API_KEY. Read-only by default; destructive (active-response)
# tools require write to be granted explicitly.
# MCP_API_KEY_SCOPES=wazuh:read wazuh:write

# Advanced: Multiple API keys (JSON array format)
# Only use if you need multiple keys with different scopes
# API_KEYS=[{"id":"key1","name":"Production","key_hash":"...","scopes":["wazuh:read"]}]

# === OAuth 2.0 (only when AUTH_MODE=oauth) ===
# OAUTH_ISSUER_URL=https://your-public-url        # auto-derived from request if unset
# OAUTH_ENABLE_DCR=false                          # Dynamic Client Registration (unauthenticated; keep off unless needed)
# OAUTH_ACCESS_TOKEN_TTL=3600
# OAUTH_REFRESH_TOKEN_TTL=86400
# OAUTH_AUTHORIZATION_CODE_TTL=600

# === Rate Limiting ===
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW=60
# Comma-separated proxy IPs to trust for X-Forwarded-For (required for correct
# per-client rate limiting behind a reverse proxy / load balancer).
# TRUSTED_PROXIES=10.0.0.1,10.0.0.2

# === CORS Configuration ===
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://claude.ai,https://*.anthropic.com,http://localhost:*

# === TLS / HTTPS ===
# The server listens over plain HTTP on MCP_PORT. Terminate TLS at a reverse
# proxy (nginx/Caddy/Traefik) or load balancer in front of it — there is no
# built-in HTTPS listener.

# === Logging ===
LOG_LEVEL=INFO
# MAX_MEMORY_MB=512   # used for the memory-usage ratio in /health and /metrics

# === Wazuh SSL ===
# SECURITY: Set WAZUH_VERIFY_SSL=true in production!
# Only set to false for development with self-signed certificates
WAZUH_VERIFY_SSL=true
# WAZUH_ALLOW_SELF_SIGNED=true  # Uncomment only for dev/testing

# === Wazuh Indexer Configuration (Required for Wazuh 4.8.0+) ===
# The vulnerability API was removed in Wazuh 4.8.0 and replaced with Indexer queries.
# Configure these settings to enable vulnerability tools.
# WAZUH_INDEXER_HOST=your-wazuh-indexer.com
# WAZUH_INDEXER_PORT=9200
# WAZUH_INDEXER_USER=admin
# WAZUH_INDEXER_PASS=admin
# Transport scheme for the indexer. Defaults to HTTPS. Set to false for a plain-HTTP
# OpenSearch node (you can also just put http:// in WAZUH_INDEXER_HOST).
# WAZUH_INDEXER_SSL=true
# Verify the indexer's TLS certificate. Set to false for self-signed certs in dev.
# WAZUH_INDEXER_VERIFY_SSL=true

# === Session Storage (Serverless Ready) ===
# Optional Redis URL for serverless/multi-instance deployments
# If not set, uses in-memory storage (single-instance only)
# REDIS_URL=redis://localhost:6379/0
# SESSION_TTL_SECONDS=1800